[Unit]
Description=tellme — premium talking clock
Documentation=https://github.com/CyrilEtornam/tellme
# Wait for the graphical session so audio and the tray are available.
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/tellme
Restart=on-failure
RestartSec=5
# Keep it lightweight and let PulseAudio/PipeWire own the audio session.
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=graphical-session.target
